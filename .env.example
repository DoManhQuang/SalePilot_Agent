# LLM — multi-provider. Fill in ONE or BOTH keys.
# LLM_PROVIDER picks the active provider; if its key is empty the app auto-uses
# whichever key IS set. With no key at all, the offline rule-based advisor runs.
LLM_PROVIDER=openai
# OpenAI (or any OpenAI-compatible provider): put the key here.
OPENAI_API_KEY=
# OpenAI-compatible endpoint base URL. Empty = official OpenAI.
# Examples: Groq https://api.groq.com/openai/v1 · OpenRouter https://openrouter.ai/api/v1
#           DeepSeek https://api.deepseek.com/v1 · Together https://api.together.xyz/v1
#           local vLLM/Ollama/LM Studio http://host.docker.internal:11434/v1
# When set, MODEL_NAME is used verbatim (e.g. llama-3.3-70b, deepseek-chat).
OPENAI_BASE_URL=
# Anthropic: key from console.anthropic.com (MODEL_NAME e.g. claude-haiku-4-5, claude-sonnet-5, claude-opus-4-8)
ANTHROPIC_API_KEY=
# MODEL_NAME must match the active provider; if it doesn't, a safe default for that provider is used.
MODEL_NAME=gpt-4o-mini
# Tốc độ / chất lượng hiển thị:
#   FAST_PATH_PHRASING=false (mặc định) → trả top-3 dạng Markdown có cấu trúc, tức thì, KHÔNG gọi LLM;
#     hiển thị đẹp trên chat UI và tiết kiệm token cho các truy vấn cần suy luận.
#   FAST_PATH_PHRASING=true → gọi LLM 1 lần diễn đạt lại thành văn xuôi (chậm hơn, tốn token).
FAST_PATH_PHRASING=false
LLM_MAX_TOKENS=700
LLM_TIMEOUT_S=45

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CHROMA_PATH=./data/chroma

# PostgreSQL — primary relational store (CRM, catalog mirror, KB).
# Local dev (host): connect to the docker-published port 5433.
# Async URL for the app (asyncpg); sync DSN for the catalog engine + ETL (psycopg2).
DATABASE_URL=postgresql+asyncpg://salepilot:salepilot@localhost:5433/salepilot
POSTGRES_DSN=postgresql+psycopg2://salepilot:salepilot@localhost:5433/salepilot
CATALOG_BACKEND=postgres
# Docker compose overrides DATABASE_URL/POSTGRES_DSN to use the postgres service hostname.
POSTGRES_USER=salepilot
POSTGRES_PASSWORD=salepilot
POSTGRES_DB=salepilot

# MongoDB (product catalog — secondary/document store, all categories)
# Local dev (host): connect to the docker-published port.
MONGODB_URI=mongodb://salepilot:salepilot@localhost:27017/salepilot?authSource=admin
MONGODB_DB=salepilot
# Docker compose overrides MONGODB_URI to use the mongo service hostname.
MONGO_ROOT_USER=salepilot
MONGO_ROOT_PASSWORD=salepilot
MONGO_DB=salepilot

# Local MCP bridge: required only to create CRM leads through MCP.
MCP_WRITE_TOKEN=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Zalo OA (stub)
ZALO_ENABLED=true
ZALO_CLIENT=mock
ZALO_OA_ACCESS_TOKEN=
ZALO_OA_SECRET=
ZALO_WEBHOOK_SECRET=
ZALO_VERIFY_MODE=off

# Features
MEMORY_ENABLED=true
AUTO_SKILL_WRITE=false
SANDBOX_ENABLED=true
WEB_FETCH_ENABLED=true
SCHEDULER_ENABLED=true
TRAJECTORY_ENABLED=true
MAX_SUBAGENTS_PER_TURN=3
